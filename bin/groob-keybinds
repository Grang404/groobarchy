#!/usr/bin/env bash

CONFIG_FILE="$DOTS/hypr/shared/keybinds.lua"
PROFILE_CONFIG_FILE="$DOTS/hypr/$PROFILE/device-keybinds.lua"
ROFI_THEME_DIR="$DOTS/rofi"
ROFI_THEME="keybinds"

if ! command -v rofi &>/dev/null; then
	echo "Error: rofi is not installed"
	exit 1
fi

if [[ ! -f "$CONFIG_FILE" ]]; then
	rofi -e "Hyprland config file not found at $CONFIG_FILE"
	exit 1
fi

extract_keybinds() {
	local file="$1"
	[[ ! -f "$file" ]] && return
	awk '
		/-- KEYBINDS_SKIP_START/ { skip = 1; next }
		/-- KEYBINDS_SKIP_END/   { skip = 0; next }
		skip { next }

		/--[[:space:]]*KEYBIND:[[:space:]]*/ {
			if (match($0, /--[[:space:]]*KEYBIND:[[:space:]]*([^→]+)[[:space:]]*→[[:space:]]*(.+)$/, arr)) {
				gsub(/^[[:space:]]+|[[:space:]]+$/, "", arr[1])
				gsub(/^[[:space:]]+|[[:space:]]+$/, "", arr[2])
				printf "%-40s → %s\n", arr[1], arr[2]
			}
			next
		}

		/hl\.bind[a-z]*[[:space:]]*\(/ {
			desc = ""
			if (match($0, /--[[:space:]]*(.+)$/, arr)) desc = arr[1]

			if (match($0, /hl\.bind[a-z]*[[:space:]]*\([[:space:]]*"([^"]+)"/, arr)) {
				keys = arr[1]
			} else {
				keys = "Unknown"
			}

			if (desc != "") {
				action = desc
			} else if (match($0, /,[[:space:]]*(.+)\)[[:space:]]*(--.*)?$/, arr)) {
				action = arr[1]
				gsub(/[[:space:]]*\)[[:space:]]*$/, "", action)
			} else {
				action = "?"
			}

			printf "%-40s → %s\n", keys, action
		}
	' "$file"
}
main() {
	local keybinds
	keybinds=$(extract_keybinds "$CONFIG_FILE")

	if [[ -f "$PROFILE_CONFIG_FILE" ]]; then
		local device_keybinds
		device_keybinds=$(extract_keybinds "$PROFILE_CONFIG_FILE")
		[[ -n "$device_keybinds" ]] && keybinds+=$'\n'"$device_keybinds"
	fi

	keybinds=$(echo "$keybinds" | sort)

	if [[ -z "$keybinds" ]]; then
		rofi -e "No keybinds found"
		exit 1
	fi

	echo "$keybinds" | rofi -dmenu \
		-i \
		-p "Hyprland Keybinds" \
		-theme "${ROFI_THEME_DIR}/${ROFI_THEME}.rasi" \
		-no-custom
}

main
